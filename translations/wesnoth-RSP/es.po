#. [multiplayer_side], id=Ref Deep Saurians
#. [multiplayer_side], id=Ref Desert Saurians
#. [multiplayer_side], id=Ref Saurians Thief
#. [multiplayer_side], id=Ref Saurians Thief NOMASK
#. [multiplayer_side], id=Ref Saurians
#. [multiplayer_side], id=Ref Undead Saurians
#: Refumees_Saurian_Pack/faction/deep-saurians-default.cfg:12
#: Refumees_Saurian_Pack/faction/desert-saurians-default.cfg:12
#: Refumees_Saurian_Pack/faction/saurians-band-default.cfg:12
#: Refumees_Saurian_Pack/faction/saurians-band-default2.cfg:12
#: Refumees_Saurian_Pack/faction/saurians-default.cfg:12
#: Refumees_Saurian_Pack/faction/undead-saurians-default.cfg:12
msgid ""
"This is an faction of tribal <ref>text='Saurians' dst='..race_lizard'</ref>. "
"They are played best as an highly mobile strikeforce, using their mobility "
"advantage to constantly mount hit and run attacks against their opponents to "
"harass them, never giving their opponents enough time to catch breath."
msgstr ""
"Esta es una facción de <ref>text='Saurios' dst='..race_lizard'</ref> "
"tribales. Se juegan mejor como una fuerza de ataque de alta movilidad, "
"aprovechando su ventaja de movimiento para ejecutar constantemente ataques "
"de golpe y huida contra sus rivales y hostigarlos, sin darles nunca el "
"tiempo suficiente para recuperar el aliento."

#. [multiplayer_side], id=Ref Desert Saurians
#: Refumees_Saurian_Pack/faction/desert-saurians-default.cfg:4
