#: Refumees_Saurian_Pack/images/units/unused/saurian-swamp/Magic_Summoner.cfg:18
msgid "Description pending."
msgstr "Descripción pendiente."

#. [attack], type=impact, range=melee
#: Refumees_Saurian_Pack/images/units/unused/saurian-swamp/Magic_Despoiler.cfg:31
msgid "cursed staff"
msgstr "bastón maldito"

#. [attack], type=unholy, range=short
#: Refumees_Saurian_Pack/images/units/unused/saurian-swamp/Magic_Despoiler.cfg:45
#: Refumees_Saurian_Pack/images/units/unused/saurian-swamp/Magic_Profaner.cfg:45
msgid "blight"
msgstr "plaga"

#. [unit_type], id=Exi Saurian Elementalist, race=exi_lizard
#. [unit_type], id=Ref Saurian Elementalist, race=lizard, gender=male
#: Refumees_Saurian_Pack/images/units/unused/saurian-swamp/Magic_Elementalist.cfg:4
#: Refumees_Saurian_Pack/units/saurians/S2-Elementalist.cfg:4
msgid "Saurian Elementalist"
msgstr "Elementalista Saurio"

#. [attack], type=fire, range=ranged
#. [attack], type=fire, range=short
#: Refumees_Saurian_Pack/images/units/unused/saurian-swamp/Magic_Elementalist.cfg:31
#: Refumees_Saurian_Pack/images/units/unused/saurian-swamp/Magic_Elementalist.cfg:43
