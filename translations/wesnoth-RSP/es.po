msgstr ""
"Necesito una unidad con un par de modificaciones de rasgos como <i>rápido</"
"i> y <i>resistente</i>."

#. [option]
#: Refumees_Saurian_Pack/macros/unit-utils.cfg:227
msgid ""
"I need a unit with a pair of trait modifications as <i>quick</i> and "
"<i>strong</i>."
msgstr ""
"Necesito una unidad con un par de modificaciones de rasgos como <i>rápido</"
"i> y <i>fuerte</i>."

#. [option]
#: Refumees_Saurian_Pack/macros/unit-utils.cfg:247
msgid ""
"I need a unit with a pair of trait modifications as <i>quick</i> and "
"<i>intelligent</i>."
msgstr ""
"Necesito una unidad con un par de modificaciones de rasgos como <i>rápido</"
"i> y <i>inteligente</i>."

#. [option]
#: Refumees_Saurian_Pack/macros/unit-utils.cfg:267
msgid ""
"I need a unit with a pair of trait modifications as <i>strong</i> and "
"<i>intelligent</i>."
msgstr ""
"Necesito una unidad con un par de modificaciones de rasgos como <i>fuerte</"
"i> y <i>inteligente</i>."

#. [option]
#: Refumees_Saurian_Pack/macros/unit-utils.cfg:287
msgid ""
"I need a unit with a pair of trait modifications as <i>strong</i> and "
"<i>resilient</i>."
msgstr ""
"Necesito una unidad con un par de modificaciones de rasgos como <i>fuerte</"
"i> y <i>resistente</i>."

#. [option]
#: Refumees_Saurian_Pack/macros/unit-utils.cfg:307
msgid ""
"I need a unit with a pair of trait modifications as <i>intelligent</i> and "
"<i>resilient</i>."
msgstr ""
"Necesito una unidad con un par de modificaciones de rasgos como "
"<i>inteligente</i> y <i>resistente</i>."

#. [option]
#: Refumees_Saurian_Pack/macros/unit-utils.cfg:327
msgid "Please, dont ask me any more."
msgstr "Por favor, no me preguntes más."

#. [unstore_unit]
#: Refumees_Saurian_Pack/macros/utils_campaign.cfg:225
msgid "2"
msgstr "2"

#. [unstore_unit]
#: Refumees_Saurian_Pack/macros/utils_campaign.cfg:295
msgid "$SWAMPRUNE"
msgstr "$SWAMPRUNE"

#. [note]
#: Refumees_Saurian_Pack/macros/utils_objectives.cfg:84
msgid "Anexir can recruit level 0 units."
msgstr "Anexir puede reclutar unidades de nivel 0."

#. [note]
#: Refumees_Saurian_Pack/macros/utils_objectives.cfg:87
