"destello de cristal (+1 de daño al destello de cristal, sin sanación "
"completa)"

#: Refumees_Saurian_Pack/units/campaign-saurians/Hero-Anexir.cfg:4
msgid ""
"Anexir is a young skillfull augur. Chosen to advise Zanza in her upcoming "
"adventure."
msgstr ""
"Anexir es un joven augurio habilidoso. Fue elegido para aconsejar a Zanza en "
"su próxima aventura."

#. [advancement], id=warrior_1
#: Refumees_Saurian_Pack/units/campaign-saurians/Hero-Anexir.cfg:9
msgid "<span color='#9A9A16'><b>Self defence</b></span>\n"
msgstr "<span color='#9A9A16'><b>Autodefensa</b></span>\n"

